generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}


enum Job {
  teacher
  services
  health
  at_home
  other
}

enum AcademicBatch {
  ELEVEN
  TWELVE
}

enum Faculty {
  SCIENCE
  MANAGEMENT
}

enum Section {
  BIO
  CS
  ECONOMICS
  MARKETING
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(TEACHER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  studentProfile Student?
  noticesAuthored Notice[]
  noticeRecipients NoticeRecipient[]
  createdAssignments Assignment[]
  attendance Attendance[]
  marks      Mark[]
  subjectAssignments TeacherSubjectAssignment[]
  classTeacherAssignments ClassTeacherAssignment[]
}

model Student {
  id         Int       @id @default(autoincrement())
  firstName  String
  lastName   String
  rollNumber String
  batch      AcademicBatch
  faculty    Faculty
  section    Section
  motherJob  Job
  fatherJob  Job
  travelTime Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user       User?     @relation(fields: [userId], references: [id])
  userId     Int?      @unique

  attendance Attendance[]
  marks      Mark[]
  predictions Prediction[]
  assignmentSubmissions AssignmentSubmission[]

  @@index([batch, faculty, section])
  @@unique([batch, faculty, section, rollNumber])
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  scope     String   // ALL | CLASS | INDIVIDUAL
  batch     AcademicBatch?
  faculty   Faculty?
  section   Section?
  authorId  Int
  createdAt DateTime @default(now())

  author    User     @relation(fields: [authorId], references: [id])
  recipients NoticeRecipient[]
}

model NoticeRecipient {
  id        Int      @id @default(autoincrement())
  noticeId  Int
  userId    Int
  read      Boolean  @default(false)
  readAt    DateTime?

  notice    Notice   @relation(fields: [noticeId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([noticeId, userId])
  @@index([userId])
}

model Subject {
  id             Int      @id @default(autoincrement())
  name           String
  faculty        Faculty?
  isOptional     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignments    TeacherSubjectAssignment[]
  attendanceRows Attendance[]

  @@unique([name, faculty])
  @@index([faculty])
}

model TeacherSubjectAssignment {
  id        Int            @id @default(autoincrement())
  teacherId Int
  subjectId Int
  batch     AcademicBatch?
  createdAt DateTime       @default(now())

  teacher   User           @relation(fields: [teacherId], references: [id])
  subject   Subject        @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId, batch])
  @@index([teacherId])
  @@index([subjectId])
}

model ClassTeacherAssignment {
  id        Int           @id @default(autoincrement())
  teacherId Int
  batch     AcademicBatch
  faculty   Faculty
  section   Section
  createdAt DateTime      @default(now())

  teacher   User          @relation(fields: [teacherId], references: [id])

  @@unique([batch, faculty, section])
  @@unique([teacherId])
  @@index([teacherId])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  date      DateTime
  present   Boolean  @default(true)
  createdAt DateTime @default(now())

  student   Student  @relation(fields: [studentId], references: [id])
  studentId Int

  teacher   User     @relation(fields: [teacherId], references: [id])
  teacherId Int

  subject   Subject? @relation(fields: [subjectId], references: [id])
  subjectId Int?

  @@unique([studentId, date])
  @@index([teacherId])
  @@index([date])
  @@index([subjectId])
}

model Mark {
  id         Int      @id @default(autoincrement())
  g1         Int
  g2         Int
  finalGrade Int?
  activities Boolean  @default(false)
  createdAt  DateTime @default(now())

  student   Student  @relation(fields: [studentId], references: [id])
  studentId Int

  teacher   User     @relation(fields: [teacherId], references: [id])
  teacherId Int

  @@index([studentId])
  @@index([teacherId])
}

model Prediction {
  id             Int      @id @default(autoincrement())
  predictedGrade Int
  payload        Json
  createdAt      DateTime @default(now())

  student   Student  @relation(fields: [studentId], references: [id])
  studentId Int

  @@index([studentId])
}

model Assignment {
  id            Int                 @id @default(autoincrement())
  title         String
  description   String?
  dueDate       DateTime?
  batch         AcademicBatch
  faculty       Faculty
  section       Section
  attachmentUrl String?
  attachmentName String?
  createdById   Int
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  createdBy     User                @relation(fields: [createdById], references: [id])
  submissions   AssignmentSubmission[]

  @@index([batch, faculty, section])
  @@index([createdById])
}

model AssignmentSubmission {
  id            Int        @id @default(autoincrement())
  assignmentId  Int
  studentId     Int
  note          String?
  attachmentUrl String?
  attachmentName String?
  submittedAt   DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  assignment    Assignment @relation(fields: [assignmentId], references: [id])
  student       Student    @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@index([studentId])
}