generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
}

enum Job {
  teacher
  services
  health
  at_home
  other
}

enum AcademicBatch {
  ELEVEN
  TWELVE
}

enum Faculty {
  SCIENCE
  MANAGEMENT
}

enum Section {
  BIO
  CS
  ECONOMICS
  MARKETING
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(TEACHER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  attendance Attendance[]
  marks      Mark[]
  subjectAssignments TeacherSubjectAssignment[]
  classTeacherAssignments ClassTeacherAssignment[]
}

model Student {
  id         Int       @id @default(autoincrement())
  firstName  String
  lastName   String
  rollNumber String
  batch      AcademicBatch
  faculty    Faculty
  section    Section
  motherJob  Job
  fatherJob  Job
  travelTime Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  attendance Attendance[]
  marks      Mark[]
  predictions Prediction[]

  @@index([batch, faculty, section])
  @@unique([batch, faculty, section, rollNumber])
}

model Subject {
  id             Int      @id @default(autoincrement())
  name           String
  faculty        Faculty?
  isOptional     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignments    TeacherSubjectAssignment[]
  attendanceRows Attendance[]

  @@unique([name, faculty])
  @@index([faculty])
}

model TeacherSubjectAssignment {
  id        Int            @id @default(autoincrement())
  teacherId Int
  subjectId Int
  batch     AcademicBatch?
  createdAt DateTime       @default(now())

  teacher   User           @relation(fields: [teacherId], references: [id])
  subject   Subject        @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId, batch])
  @@index([teacherId])
  @@index([subjectId])
}

model ClassTeacherAssignment {
  id        Int           @id @default(autoincrement())
  teacherId Int
  batch     AcademicBatch
  faculty   Faculty
  section   Section
  createdAt DateTime      @default(now())

  teacher   User          @relation(fields: [teacherId], references: [id])

  @@unique([batch, faculty, section])
  @@unique([teacherId])
  @@index([teacherId])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  date      DateTime
  present   Boolean  @default(true)
  createdAt DateTime @default(now())

  student   Student  @relation(fields: [studentId], references: [id])
  studentId Int

  teacher   User     @relation(fields: [teacherId], references: [id])
  teacherId Int

  subject   Subject? @relation(fields: [subjectId], references: [id])
  subjectId Int?

  @@unique([studentId, date])
  @@index([teacherId])
  @@index([date])
  @@index([subjectId])
}

model Mark {
  id         Int      @id @default(autoincrement())
  g1         Int
  g2         Int
  finalGrade Int?
  activities Boolean  @default(false)
  createdAt  DateTime @default(now())

  student   Student  @relation(fields: [studentId], references: [id])
  studentId Int

  teacher   User     @relation(fields: [teacherId], references: [id])
  teacherId Int

  @@index([studentId])
  @@index([teacherId])
}

model Prediction {
  id             Int      @id @default(autoincrement())
  predictedGrade Int
  payload        Json
  createdAt      DateTime @default(now())

  student   Student  @relation(fields: [studentId], references: [id])
  studentId Int

  @@index([studentId])
}